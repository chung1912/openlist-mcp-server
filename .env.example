OPENLIST_URL=https://your-openlist-instance.example.com
OPENLIST_USERNAME=your_username
OPENLIST_PASSWORD=your_password
# Optional: make the MCP server read-only. Blocks uploads, delete, move, copy,
# rename, shares, offline downloads, task mutations, and archive decompression.
OPENLIST_READONLY=false
# Optional: comma-separated OpenList path prefixes this MCP server may access.
# Empty means no MCP-side path restriction. Example: /mcp-dev-test,/public
OPENLIST_ALLOWED_PATHS=
# Required: restrict upload_local_file to specific local directories (os.pathsep-separated).
# This tool is DISABLED by default. Set this variable to enable it.
# Linux/macOS example: /tmp:/path/to/uploads ; Windows example: C:\\Temp;D:\\Uploads
OPENLIST_LOCAL_UPLOAD_ROOTS=
# Optional integration-test directory. Defaults to /.
OPENLIST_TEST_DIR=/
# Optional: TOTP secret for auto-generating 2FA codes during login.
# Only needed if your OpenList account has 2FA enabled and you want automatic OTP generation.
OPENLIST_TOTP_SECRET=
# Optional: skill groups to load. Defaults to "core" (25 most common tools).
#   core    - auth + file operations + upload/download (~25 tools)
#   default - core + task management + shares (~44 tools)
#   all     - every tool (~79 tools)
# Custom: comma-separated group names (fs,transfer,task,share,admin,advanced)
OPENLIST_SKILLS=core
