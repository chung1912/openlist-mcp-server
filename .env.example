OPENLIST_URL=https://your-openlist-instance.example.com
OPENLIST_USERNAME=your_username
OPENLIST_PASSWORD=your_password
# Optional: restrict upload_local_file to specific local directories (os.pathsep-separated).
# Linux/macOS example: /tmp:/path/to/uploads ; Windows example: C:\\Temp;D:\\Uploads
OPENLIST_LOCAL_UPLOAD_ROOTS=
# Optional integration-test directory. Defaults to /.
OPENLIST_TEST_DIR=/
